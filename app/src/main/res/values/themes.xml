<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SofaStream" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/surface_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Text input fields dark style -->
        <item name="colorOnSurface">@color/white</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.SofaStream.TextInputLayout</item>
    </style>

    <style name="ThemeOverlay.SofaStream.TextInputLayout" parent="">
        <item name="colorOnSurface">@color/white</item>
        <item name="colorPrimary">@color/accent_color</item>
    </style>

    <style name="Theme.SofaStream.Player" parent="Theme.SofaStream">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Theme.SofaStream.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@color/surface_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>
    </style>

</resources>

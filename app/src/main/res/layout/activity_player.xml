<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <!-- ExoPlayer surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="fit" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Error message -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- Skip backward indicator -->
    <TextView
        android:id="@+id/skipBackwardIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="60dp"
        android:text="⏮ -10s"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:background="#66000000"
        android:padding="12dp"
        android:visibility="gone" />

    <!-- Skip forward indicator -->
    <TextView
        android:id="@+id/skipForwardIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="60dp"
        android:text="+10s ⏭"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:background="#66000000"
        android:padding="12dp"
        android:visibility="gone" />

    <!-- Top bar: title + back + PIP -->
    <LinearLayout
        android:id="@+id/playerTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/gradient_top_overlay"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="@string/nav_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="8dp">

            <TextView
                android:id="@+id/tvPlayerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPlayerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnPip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_pip"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Picture in Picture"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Bottom controls overlay -->
    <LinearLayout
        android:id="@+id/playerControlsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/gradient_bottom_overlay"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <!-- Progress bar -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/playerProgressBar"
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:layout_marginBottom="8dp"
            app:played_color="@color/accent_color"
            app:unplayed_color="#55FFFFFF"
            app:buffered_color="#88FFFFFF"
            app:scrubber_color="@color/accent_color"
            app:scrubber_enabled_size="14dp"
            app:scrubber_dragged_size="18dp"
            app:scrubber_disabled_size="10dp" />

        <!-- Play controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Rewind 10 seconds -->
            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_replay_10"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Rewind 10 seconds" />

            <!-- Play/Pause -->
            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginHorizontal="24dp"
                android:src="@drawable/ic_pause"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Play Pause" />

            <!-- Forward 10 seconds -->
            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_forward_10"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Forward 10 seconds" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
